<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="WinMD.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinMD">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="EditorCanvasBrush" Color="#EAE9F1" />
                    <SolidColorBrush x:Key="ToolbarSurfaceBrush" Color="#F5F3FC" />
                    <SolidColorBrush x:Key="PageSurfaceBrush" Color="#F2F1F8" />
                    <!-- Pasek formatowania: wyraźny szary panel + jaśniejsze, obramowane przyciski -->
                    <SolidColorBrush x:Key="FormatBarSurfaceBrush" Color="#D2D2DA" />
                    <SolidColorBrush x:Key="FormatButtonBrush" Color="#ECECF2" />
                    <SolidColorBrush x:Key="FormatButtonBorderBrush" Color="#A6A6B2" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="EditorCanvasBrush" Color="#26262A" />
                    <SolidColorBrush x:Key="ToolbarSurfaceBrush" Color="#1E1E1E" />
                    <SolidColorBrush x:Key="PageSurfaceBrush" Color="#121212" />
                    <SolidColorBrush x:Key="FormatBarSurfaceBrush" Color="#1E1E1E" />
                    <SolidColorBrush x:Key="FormatButtonBrush" Color="#2D2D30" />
                    <SolidColorBrush x:Key="FormatButtonBorderBrush" Color="#3A3A3C" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <SolidColorBrush x:Key="PrimaryBrush" Color="#512BD4" />
            <local:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
